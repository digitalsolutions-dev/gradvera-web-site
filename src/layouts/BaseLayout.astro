---
// Self-hosted IBM Plex (matches the design's --font-sans / --font-mono stacks).
// Self-hosting avoids the Google Fonts hotlink (GDPR) and a render-blocking request.
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-sans/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
// Site stylesheets — imported (not linked from public/) so Vite bundles,
// minifies, and fingerprints them for immutable caching. IMPORT ORDER IS THE
// CASCADE: tokens -> site -> cap1 -> cap -> site-polish (the corrections layer
// must load last so its overrides win).
import '../styles/gradvera-tokens.css';
import '../styles/site.css';
import '../styles/cap1-screens.css';
import '../styles/cap-screens.css';
import '../styles/site-polish.css';
import SEO from '../components/seo/SEO.astro';
import Header from '../components/layout/Header.astro';
import MobileNav from '../components/layout/MobileNav.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/marketing/CookieConsent.astro';
import Analytics from '../components/marketing/Analytics.astro';
import { useTranslations, LOCALE_META, type Locale } from '../i18n/utils';

interface Props {
  lang?: Locale;
  /** Canonical, locale-stripped path for canonical/hreflang, e.g. '/', '/book-a-demo/'. */
  path: string;
  title?: string;
  description?: string;
  ogType?: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const {
  lang = 'en',
  path,
  title,
  description,
  ogType,
  image,
  noindex,
  jsonLd,
} = Astro.props;

const t = useTranslations(lang);
const htmlLang = LOCALE_META[lang].htmlLang;
---
<!doctype html>
<html lang={htmlLang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      lang={lang}
      path={path}
      title={title}
      description={description}
      ogType={ogType}
      image={image}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    {/* Site CSS is imported in the frontmatter above (Vite-bundled + hashed). */}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('a11y.skipToContent')}</a>
    <div class="scroll-progress" aria-hidden="true"></div>
    <Header lang={lang} path={path} />
    <MobileNav lang={lang} path={path} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />
    <Analytics />
    <script>
      // Bundled + minified + fingerprinted by Astro/Vite (was public/assets/site.js).
      import '../scripts/site.js';
    </script>
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 1000;
    background: var(--brand-primary, #2563eb);
    color: var(--brand-on-primary, #1A1916);
    padding: 10px 16px;
    border-radius: 0 0 8px 0;
    font: 500 14px/1.2 system-ui, sans-serif;
  }
  .skip-link:focus {
    left: 0;
  }
</style>
