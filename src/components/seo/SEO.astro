---
import { SITE, COMPANY } from '../../consts';
import {
  localizePath,
  alternates,
  absoluteUrl,
  LOCALE_META,
  type Locale,
} from '../../i18n/utils';

interface Props {
  lang: Locale;
  /** Canonical, locale-stripped path, e.g. '/', '/book-a-demo/'. */
  path: string;
  title?: string;
  description?: string;
  image?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const {
  lang,
  path,
  title = SITE.defaultTitle,
  description = SITE.defaultDescription,
  image,
  ogType = 'website',
  noindex = false,
  jsonLd = [],
} = Astro.props;

const site = Astro.site;
const siteOrigin = site ? String(site).replace(/\/$/, '') : SITE.url;

// Force noindex on any non-production deploy (Vercel Preview / staging) so
// pre-production URLs are never indexed — even on a custom preview domain, where
// Vercel's automatic *.vercel.app noindex header does NOT apply. At build time
// VERCEL_ENV is 'production' on the prod deploy, 'preview' for previews, and
// unset locally (local builds are never deployed, so they index normally).
const vercelEnv = process.env.VERCEL_ENV;
const robotsNoindex = noindex || (vercelEnv !== undefined && vercelEnv !== 'production');

const canonical = absoluteUrl(localizePath(path, lang), site);
const ogImage = absoluteUrl(image ?? SITE.ogImage, site);
const alts = alternates(path).map((a) => ({ ...a, href: absoluteUrl(a.path, site) }));
const ogLocale = LOCALE_META[lang].ogLocale;
const ogAltLocales = (Object.keys(LOCALE_META) as Locale[])
  .filter((l) => l !== lang)
  .map((l) => LOCALE_META[l].ogLocale);

// --- Site-wide structured data (present on every page) ---
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: COMPANY.legalName,
  alternateName: COMPANY.brand,
  url: siteOrigin,
  logo: absoluteUrl('/favicons/android-chrome-512x512.png', site),
  email: COMPANY.email,
  telephone: COMPANY.phoneDisplay,
  sameAs: [COMPANY.linkedin],
  address: {
    '@type': 'PostalAddress',
    addressLocality: COMPANY.address.locality,
    addressCountry: COMPANY.address.countryCode,
  },
};

const webSiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: COMPANY.brand,
  url: siteOrigin,
  inLanguage: LOCALE_META[lang].htmlLang,
  publisher: { '@type': 'Organization', name: COMPANY.legalName },
};

const structuredData = [organizationLd, webSiteLd, ...jsonLd];
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{
  robotsNoindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
  )
}

{/* hreflang alternates (incl. x-default) */}
{alts.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

{/* Open Graph */}
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={COMPANY.brand} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${COMPANY.brand} — ${COMPANY.tagline}`} />
<meta property="og:locale" content={ogLocale} />
{ogAltLocales.map((l) => <meta property="og:locale:alternate" content={l} />)}

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{/* Icons & theme */}
<meta name="theme-color" content={SITE.themeColor} />
<link rel="icon" href="/favicons/favicon.ico" sizes="any" />
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
<link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png" />
<link rel="manifest" href="/favicons/site.webmanifest" />

{/* Structured data */}
{
  structuredData.map((ld) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
  ))
}
