---
import { localizePath, useTranslations, type Locale } from '../../i18n/utils';
import LangSwitch from './LangSwitch.astro';
interface Props { lang: Locale; path?: string }
const { lang, path } = Astro.props;
const t = useTranslations(lang);
const switchPath = path ?? '/';
// On the home page use bare same-page anchors (`#helps`) so site.js's scrollspy
// (`.nav a[href^="#"]`) matches; on subpages prefix the localized home path.
const homeHref = (hash: string) => (switchPath === '/' ? '' : localizePath('/', lang)) + hash;
---
<header class="hdr">
  <div class="wrap">
    <a class="brand" href={localizePath('/', lang)} aria-label={t('a11y.home')}>
      <span class="mono-tile"><img class="mono" src="/assets/monogram.svg" alt=""></span>
      <span class="wm">Gradvera</span>
    </a>
    <nav class="nav">
      <a href={homeHref('#helps')}>{t('nav.helps')}</a>
      <a href={homeHref('#works')}>{t('nav.works')}</a>
      <a href={homeHref('#outcomes')}>{t('nav.outcomes')}</a>
    </nav>
    <div class="nav-cta">
      <LangSwitch lang={lang} path={switchPath} />
      <a class="btn btn-primary" href={localizePath('/book-a-demo/', lang)}>{t('cta.bookDemo')}</a>
      <button class="btn menu-btn" aria-label={t('a11y.openMenu')} data-close-label={t('a11y.closeMenu')} aria-controls="mobile-nav" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

