---
import { LOCALES, LOCALE_META, localizePath, useTranslations, type Locale } from '../../i18n/utils';
interface Props { lang: Locale; path?: string }
const { lang, path } = Astro.props;
const t = useTranslations(lang);
const switchPath = path ?? '/';
// On the home page use bare same-page anchors (`#helps`) so site.js's scrollspy
// (`.nav a[href^="#"]`) matches; on subpages prefix the localized home path.
const homeHref = (hash: string) => (switchPath === '/' ? '' : localizePath('/', lang)) + hash;
---
<header class="hdr">
  <div class="wrap">
    <a class="brand" href={localizePath('/', lang)} aria-label={t('a11y.home')}>
      <span class="mono-tile"><img class="mono" src="/assets/monogram.svg" alt=""></span>
      <span class="wm">Gradvera</span>
    </a>
    <nav class="nav">
      <a href={homeHref('#helps')}>{t('nav.helps')}</a>
      <a href={homeHref('#works')}>{t('nav.works')}</a>
      <a href={homeHref('#outcomes')}>{t('nav.outcomes')}</a>
    </nav>
    <div class="nav-cta">
      <div class="lang-switch" role="group" aria-label={t('a11y.language')}>
        {LOCALES.map((loc) => (
          <a href={localizePath(switchPath, loc)} aria-current={loc === lang ? 'true' : undefined}>{LOCALE_META[loc].htmlLang.toUpperCase()}</a>
        ))}
      </div>
      <a class="btn btn-primary" href={localizePath('/book-a-demo/', lang)}>{t('cta.bookDemo')}</a>
      <button class="btn menu-btn" aria-label={t('a11y.openMenu')} aria-controls="mobile-nav" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<style is:global>
  /* Language picker — a segmented pill control. Active locale = filled amber
     (state shown by fill, not colour alone). Used in the desktop header and,
     full-width + touch-sized, inside the mobile menu. */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--ink-hair, rgba(151, 166, 192, 0.16));
    border-radius: 999px;
  }
  .lang-switch a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    padding: 7px 11px;
    font: 600 12px/1 var(--font-mono, 'IBM Plex Mono', monospace);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--on-ink-2, #97a6c0);
    border-radius: 999px;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .lang-switch a:hover {
    color: var(--on-ink, #eef2fa);
  }
  .lang-switch a[aria-current] {
    background: var(--amber, #e8901c);
    color: #1a1208;
  }
  .lang-switch a:focus-visible {
    outline: 2px solid var(--amber, #e8901c);
    outline-offset: 2px;
  }

  /* The header is dark in both rest + scrolled (.solid) states, so the picker
     keeps light text throughout (the old .solid override used dark-mode greys
     that vanished on the navy bar). */
  .hdr.solid .lang-switch {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Declutter the cramped mobile header — the picker moves into the menu. */
  @media (max-width: 940px) {
    .hdr .lang-switch {
      display: none;
    }
  }

  /* Mobile menu: full-width, touch-sized (≥44px) segmented control. */
  .mobile-nav .lang-switch {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    width: 100%;
    margin-top: 20px;
  }
  .mobile-nav .lang-switch a {
    min-height: 46px;
    font-size: 14px;
    padding: 0;
    border-bottom: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .lang-switch a {
      transition: none;
    }
  }
</style>

<script is:inline>
  /* Keep the menu button's aria-expanded in sync with the mobile nav open state
     (site.js toggles the .open class; this only mirrors it for assistive tech). */
  (function () {
    var btn = document.querySelector('.menu-btn');
    var nav = document.getElementById('mobile-nav');
    if (!btn || !nav) return;
    function sync() { btn.setAttribute('aria-expanded', nav.classList.contains('open') ? 'true' : 'false'); }
    btn.addEventListener('click', function () { requestAnimationFrame(sync); });
    nav.addEventListener('click', function (e) { if (e.target.closest('a')) requestAnimationFrame(sync); });
    sync();
  })();
</script>
