---
import { LOCALES, LOCALE_META, localizePath, useTranslations, type Locale } from '../../i18n/utils';

/**
 * Locale switcher, one source for both placements:
 * `header` — a <details>-based dropdown (globe + current ISO code trigger,
 *   popover of code + endonym options). Native disclosure semantics, so it
 *   opens without JS; the inline script adds Escape / outside-click / arrow keys.
 * `menu`   — full-width touch cells in the mobile menu, code eyebrow + endonym.
 */
interface Props { lang: Locale; path?: string; variant?: 'header' | 'menu' }
const { lang, path, variant = 'header' } = Astro.props;
const t = useTranslations(lang);
const switchPath = path ?? '/';
---
{variant === 'header' ? (
  <details class="lang-menu">
    <summary aria-label={`${t('a11y.language')} — ${LOCALE_META[lang].label}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      <span class="lang-menu__code">{LOCALE_META[lang].htmlLang.toUpperCase()}</span>
      <svg class="lang-menu__chev" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
    </summary>
    <ul class="lang-menu__list">
      {LOCALES.map((loc) => (
        <li>
          <a
            href={localizePath(switchPath, loc)}
            hreflang={LOCALE_META[loc].htmlLang}
            lang={LOCALE_META[loc].htmlLang}
            aria-current={loc === lang ? 'page' : undefined}
          >
            <span class="lang-menu__opt-code" aria-hidden="true">{LOCALE_META[loc].htmlLang.toUpperCase()}</span>
            <span class="lang-menu__opt-name">{LOCALE_META[loc].label}</span>
            {loc === lang && (
              <svg class="lang-menu__check" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            )}
          </a>
        </li>
      ))}
    </ul>
  </details>

  <script is:inline>
    /* Dropdown niceties on top of native <details>: close on outside click,
       Escape-to-close with focus returned to the trigger, ArrowUp/Down cycling
       through the options. */
    (function () {
      var root = document.querySelector('.hdr .lang-menu');
      if (!root) return;
      var sum = root.querySelector('summary');
      /* If the viewport narrows into the burger band while the popover is
         open, the media query hides it but `open` would persist — close it so
         the document-level handlers disarm and it doesn't reappear pre-opened
         when the viewport grows back. */
      window.matchMedia('(max-width: 1199px)').addEventListener('change', function (ev) {
        if (ev.matches) root.open = false;
      });
      document.addEventListener('click', function (e) {
        if (root.open && !root.contains(e.target)) root.open = false;
      });
      document.addEventListener('keydown', function (e) {
        if (!root.open || !root.offsetParent) return;
        if (e.key === 'Escape') { e.preventDefault(); root.open = false; sum.focus(); return; }
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
          var links = root.querySelectorAll('.lang-menu__list a');
          if (!links.length) return;
          e.preventDefault();
          var idx = Array.prototype.indexOf.call(links, document.activeElement);
          var next = e.key === 'ArrowDown'
            ? (idx + 1) % links.length
            : (idx - 1 + links.length) % links.length;
          links[next].focus();
        }
      });
    })();
  </script>
) : (
  <div class="lang-switch lang-switch--menu" role="group" aria-label={t('a11y.language')}>
    {LOCALES.map((loc) => (
      <a
        href={localizePath(switchPath, loc)}
        hreflang={LOCALE_META[loc].htmlLang}
        lang={LOCALE_META[loc].htmlLang}
        aria-label={LOCALE_META[loc].label}
        aria-current={loc === lang ? 'page' : undefined}
      >
        <span class="lang-switch__code" aria-hidden="true">{LOCALE_META[loc].htmlLang.toUpperCase()}</span>
        <span class="lang-switch__name" aria-hidden="true">{LOCALE_META[loc].label}</span>
      </a>
    ))}
  </div>
)}

<style is:global>
  /* ---- Header dropdown ---------------------------------------------------- */
  .lang-menu {
    position: relative;
  }
  .lang-menu summary {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 12px;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--ink-hair, rgba(151, 166, 192, 0.16));
    border-radius: 8px;
    color: var(--on-ink-2, #97a6c0);
    font: 600 12px/1 var(--font-mono, 'IBM Plex Mono', monospace);
    letter-spacing: 0.06em;
    touch-action: manipulation;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .lang-menu summary::-webkit-details-marker {
    display: none;
  }
  .lang-menu summary:hover,
  .lang-menu[open] summary {
    background: rgba(255, 255, 255, 0.08);
    color: var(--on-ink, #eef2fa);
  }
  .lang-menu summary:focus-visible {
    outline: 2px solid var(--amber, #e8901c);
    outline-offset: 2px;
  }
  .lang-menu__chev {
    transition: transform 0.15s ease;
  }
  .lang-menu[open] .lang-menu__chev {
    transform: rotate(180deg);
  }
  /* Popover panel. z-index 70 clears the header (60) and the menu scrim (54). */
  .lang-menu__list {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    z-index: 70;
    min-width: 200px;
    margin: 0;
    padding: 4px;
    list-style: none;
    background: var(--ink-2, #141e33);
    border: 1px solid var(--ink-hair, rgba(151, 166, 192, 0.16));
    border-radius: 8px;
    box-shadow: 0 18px 40px rgba(4, 8, 20, 0.55);
  }
  .lang-menu__list a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--on-ink, #eef2fa);
  }
  .lang-menu__list a:hover {
    background: rgba(255, 255, 255, 0.06);
  }
  .lang-menu__list a:focus-visible {
    outline: 2px solid var(--amber, #e8901c);
    outline-offset: -2px;
  }
  .lang-menu__opt-code {
    min-width: 22px;
    font: 500 10px/1 var(--font-mono, 'IBM Plex Mono', monospace);
    letter-spacing: 0.18em;
    color: var(--on-ink-2, #97a6c0);
  }
  .lang-menu__opt-name {
    font: 500 14px/1.2 var(--font-sans, 'IBM Plex Sans', system-ui, sans-serif);
  }
  /* Current locale: amber-tinted row + check — state shown by mark, not colour
     alone. Same tint family as .hdr.solid .nav a.active (site-polish.css). */
  .lang-menu__list a[aria-current] {
    background: rgba(232, 144, 28, 0.14);
  }
  .lang-menu__check {
    margin-left: auto;
    color: var(--amber, #e8901c);
  }

  /* Below the full-desktop-header width the switcher moves into the mobile
     menu (see the header media band in site.css). */
  @media (max-width: 1199px) {
    .hdr .lang-menu {
      display: none;
    }
  }

  /* ---- Mobile-menu segmented cells ---------------------------------------- */
  /* Active locale = filled amber; drafting geometry (8px/6px radii). */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--ink-hair, rgba(151, 166, 192, 0.16));
    border-radius: 8px;
  }
  .lang-switch a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    padding: 7px 11px;
    font: 600 12px/1 var(--font-mono, 'IBM Plex Mono', monospace);
    letter-spacing: 0.06em;
    color: var(--on-ink-2, #97a6c0);
    border-radius: 6px;
    text-decoration: none;
    touch-action: manipulation;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  /* Hover/press are state layers (background), not colour-only changes. */
  .lang-switch a:hover {
    color: var(--on-ink, #eef2fa);
    background: rgba(255, 255, 255, 0.07);
  }
  .lang-switch a:active {
    background: rgba(255, 255, 255, 0.12);
  }
  .lang-switch a[aria-current] {
    background: var(--amber, #e8901c);
    /* --brand-on-primary (gradvera-tokens.css): warm near-black for text on
       amber fills. No literal fallback — the value is not in DESIGN.md's
       palette list, and the tokens sheet loads first in the cascade anyway. */
    color: var(--brand-on-primary);
  }
  .lang-switch a[aria-current]:active {
    background: var(--brand-primary-pressed, #9c5c0e);
  }
  .lang-switch a:focus-visible {
    outline: 2px solid var(--amber, #e8901c);
    outline-offset: 2px;
  }

  /* Menu variant: full-width, touch-sized cells. Two lines per cell — mono ISO
     eyebrow + the language's own name (endonym), so a reader who doesn't map
     "SL" still finds Slovenščina. Selectors carry the .mobile-nav context so
     they outrank site.css's `.mobile-nav a` (17px / 13px 0 / hairline border),
     which ties bare one-class selectors on specificity. */
  .mobile-nav .lang-switch--menu {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    width: 100%;
    margin-top: 20px;
    border-radius: 12px;
  }
  .mobile-nav .lang-switch--menu a {
    flex-direction: column;
    gap: 4px;
    min-height: 56px;
    padding: 10px 4px;
    border-radius: 8px;
    border-bottom: 0;
    font-size: 12px;
    color: var(--on-ink-2, #97a6c0);
  }
  /* Re-declare hover at this specificity — the base .lang-switch a:hover ties
     the block above at (0,2,1) and loses on source order. */
  .mobile-nav .lang-switch--menu a:hover {
    color: var(--on-ink, #eef2fa);
  }
  .mobile-nav .lang-switch--menu a[aria-current] {
    color: var(--brand-on-primary);
  }
  .mobile-nav .lang-switch--menu .lang-switch__code {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
  }
  .mobile-nav .lang-switch--menu .lang-switch__name {
    font-family: var(--font-sans, 'IBM Plex Sans', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: normal;
    line-height: 1.2;
    color: var(--on-ink, #eef2fa);
  }
  .mobile-nav .lang-switch--menu a[aria-current] .lang-switch__name {
    color: var(--brand-on-primary);
  }

  @media (prefers-reduced-motion: reduce) {
    .lang-switch a,
    .lang-menu summary,
    .lang-menu__chev {
      transition: none;
    }
  }
</style>
