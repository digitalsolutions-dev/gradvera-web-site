---
import { useTranslations, type Locale } from '../../i18n/utils';
interface Props { lang: Locale; path?: string }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="works" id="works">
  <div class="wrap">
    <div class="sec-head reveal">
      <p class="eyebrow">{t('works.eyebrow')}</p>
      <h2 class="h-section" style="margin-top:16px">{t('works.h2')}</h2>
    </div>
    <ol class="works-steps">
      <li class="wstep reveal">
        <div class="wn"><span class="num">01</span><span class="lab">{t('works.s1lab')}</span></div>
        <div class="wc">
          <h3>{t('works.s1h3')}</h3>
          <p>{t('works.s1p')}</p>
        </div>
      </li>
      <li class="wstep reveal">
        <div class="wn"><span class="num">02</span><span class="lab">{t('works.s2lab')}</span></div>
        <div class="wc">
          <h3>{t('works.s2h3')}</h3>
          <p>{t('works.s2p')}</p>
          <div class="group-viz">
            <div class="descs">
              <div class="desc-chip">Concrete foundation C25/30, 150 mm</div>
              <div class="desc-chip">Concrete base slab C25/30, 15 cm</div>
              <div class="desc-chip">Reinforced concrete foundation layer</div>
            </div>
            <div class="merge">
              <div class="mline"></div>
              <span class="spk">✦</span>
              <div class="mline"></div>
            </div>
            <div class="same-item"><div class="si-k">{t('works.s2resolves')}</div><div class="si-v">{t('works.s2same')}</div></div>
          </div>
        </div>
      </li>
      <li class="wstep reveal">
        <div class="wn"><span class="num">03</span><span class="lab">{t('works.s3lab')}</span></div>
        <div class="wc">
          <h3>{t('works.s3h3')}</h3>
          <p>{t('works.s3p')}</p>
          <div class="ref-hub">
            <div class="ref-core">
              <div class="spark">✦</div>
              <div class="rk">Line item</div>
              <div class="rv">Concrete Foundation</div>
            </div>
            <div class="ref-attrs">
              <div class="ra"><div class="k">{t('works.ra1k')}</div><div class="v">{t('works.ra1v')}</div></div>
              <div class="ra"><div class="k">{t('works.ra2k')}</div><div class="v">{t('works.ra2v')}</div></div>
              <div class="ra"><div class="k">{t('works.ra3k')}</div><div class="v">{t('works.ra3v')}</div></div>
              <div class="ra"><div class="k">{t('works.ra4k')}</div><div class="v">{t('works.ra4v')}</div></div>
              <div class="ra"><div class="k">{t('works.ra5k')}</div><div class="v">{t('works.ra5v')}</div></div>
              <div class="ra"><div class="k">{t('works.ra6k')}</div><div class="v">{t('works.ra6v')}</div></div>
            </div>
          </div>
        </div>
      </li>
      <li class="wstep reveal">
        <div class="wn"><span class="num">04</span><span class="lab">{t('works.s4lab')}</span></div>
        <div class="wc">
          <h3>{t('works.s4h3')}</h3>
          <p>{t('works.s4p')}</p>
          <div class="est-viz">
            <div class="est-row"><span class="en">Concrete foundation C25/30</span><span class="ep">✦ €170 / m³</span><span class="ec"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></span></div>
            <div class="est-row"><span class="en">Excavation — rock</span><span class="ep">✦ €38 / m³</span><span class="ec"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></span></div>
            <div class="est-row pending"><span class="en">Structural steel S355</span><span class="erow"><span class="epstack"><small class="eprop">Proposed price</small><span class="ep">✦ €2,180 / t</span></span><span class="acc">Accept</span><span class="adj">Adjust</span></span></div>
            <div class="est-total"><span class="tk">Estimate in progress</span><span class="tv"></span></div>
          </div>
        </div>
      </li>
      <li class="wstep reveal">
        <div class="wn"><span class="num">05</span><span class="lab">{t('works.s5lab')}</span></div>
        <div class="wc">
          <h3>{t('works.s5h3')}</h3>
          <p>{t('works.s5p')}</p>
          <div class="loop-viz">
            <div class="loop-chips">
              <div class="loop-chip">{t('works.s5loopa')}</div>
              <div class="loop-arrow"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
              <div class="loop-chip ai"><span class="spk">✦</span>{t('works.s5loopb')}</div>
              <div class="loop-arrow"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
              <div class="loop-chip">{t('works.s5loopc')}</div>
            </div>
            <div class="loop-return"><span class="rl"></span><span class="rc"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></span><span class="rl"></span></div>
          </div>
        </div>
      </li>
    </ol>
  </div>
</section>

<style is:global>
  /* The five steps are an ordered process, marked up as <ol>/<li> so screen
     readers announce "list, 5 items" and the sequence. Reset the UA list chrome;
     the .works-steps / .wstep layout styles are class-based and unchanged. */
  ol.works-steps { list-style: none; margin: 0; padding: 0; }
</style>
