---
import { useTranslations, type Locale } from '../../i18n/utils';
interface Props { lang: Locale; path?: string }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="skyline" id="outcomes">
  <div class="wrap">
    <div class="sky-head reveal">
      <span class="sky-badge"><span class="bd-dot"></span>{t('outcomes.badge')}</span>
      <h2 style="margin-top:20px">{t('outcomes.h2')}</h2>
    </div>
    <ul class="sky-row" data-stagger>
      <li class="sky-panel"><div class="sky-top"><span class="sky-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2"/><path d="M5 3L2 6M22 6l-3-3"/></svg></span><span class="sp-n">01</span></div><p>{t('outcomes.p1')}</p></li>
      <li class="sky-panel"><div class="sky-top"><span class="sky-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></span><span class="sp-n">02</span></div><p>{t('outcomes.p2')}</p></li>
      <li class="sky-panel"><div class="sky-top"><span class="sky-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l9 5-9 5-9-5 9-5z"/><path d="M3 12l9 5 9-5"/><path d="M3 17l9 5 9-5"/></svg></span><span class="sp-n">03</span></div><p>{t('outcomes.p3')}</p></li>
      <li class="sky-panel"><div class="sky-top"><span class="sky-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg></span><span class="sp-n">04</span></div><p>{t('outcomes.p4')}</p></li>
      <li class="sky-panel"><div class="sky-top"><span class="sky-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 14l3-3 3 2 5-6"/></svg></span><span class="sp-n">05</span></div><p>{t('outcomes.p5')}</p></li>
      <li class="sky-panel"><div class="sky-top"><span class="sky-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M6 9v6M18 9c0 6-12 2-12 9"/></svg></span><span class="sp-n">06</span></div><p>{t('outcomes.p6')}</p></li>
    </ul>
  </div>
</section>

<style is:global>
  /* Outcomes panels are a semantic list now (screen readers announce "6 items").
     Reset the UA list chrome; .sky-row's grid + .sky-panel styles are unchanged. */
  ul.sky-row { list-style: none; margin: 0; padding: 0; }
</style>
