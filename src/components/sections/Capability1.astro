---
import { useTranslations, type Locale } from '../../i18n/utils';
interface Props { lang: Locale; path?: string }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="cap plain">
  <div class="wrap">
    <div class="cap-head reveal">
      <span class="cap-num">CAPABILITY 01</span>
      <div>
        <h2>{t('cap1.h2')}</h2>
        <p>{t('cap1.p')}</p>
      </div>
    </div>
    <div class="fig reveal">
      <div class="cap1-steps" role="list">
        <div class="cap1-step" role="listitem">
          <div class="cap1-text">
            <span class="cap1-badge" aria-hidden="true">1</span>
            <div class="cap1-stepk">Step 1</div>
            <h3 class="cap1-steph">{t('cap1.step1h')}</h3>
            <p class="cap1-stepd">{t('cap1.step1d')}</p>
          </div>
          <div class="gv-panelwrap" aria-hidden="true">
            <div class="winbar app"><span class="dots"><i></i><i></i><i></i></span><span class="wtitle"><img src="/assets/monogram-plain.svg" alt="">Gradvera · New estimate</span></div>
            <div class="gv-holder">
            <div class="gv-screen solo gv-screen-1" style="--gw:800px">
              <div class="gv-main">
                                <div class="gv-body">
                  <div class="gv-h"><h4>Estimate structure</h4><span class="gv-demo">Demo</span></div>
                  <p class="gv-sub">Define sections for an organised estimate. Reorder or rename later — nothing is locked.</p>
                  <div class="gv-opts">
                    <div class="gv-opt"><div class="oic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" stroke-dasharray="3 3"/></svg></div><div class="ot">Empty structure</div><div class="od">Start without predefined sections</div></div>
                    <div class="gv-opt sel"><div class="chk"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="oic"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.6 6.4L20 10l-6.4 1.6L12 18l-1.6-6.4L4 10l6.4-1.6z"/></svg></div><div class="ot">Suggested sections</div><div class="od">Sections based on project type</div><span class="tag">Residential building</span></div>
                    <div class="gv-opt"><div class="oic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></div><div class="ot">{t('mock.copyStructure')}</div><div class="od">From a similar estimate</div></div>
                  </div>
                  <div class="gv-meta">Number of sections <b>4</b> · Structure type <b>Suggested</b> · Readiness <span class="grn">Ready</span><span class="resug"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.5 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>{t('mock.reSuggest')}</span></div>
                  <div class="gv-listhead"><div><div class="lt">Estimate sections</div><div class="ls">Reorder, rename or add sections</div></div><div class="ai"><span class="gv-spark">✦</span> AI suggested for residential</div></div>
                  <div class="gv-row first"><span class="grip">⠿</span><span class="nm">Preparatory works</span><span class="right"><span class="gv-pill-s"><span class="gv-spark">✦</span>suggested</span><span class="ix">1</span><span class="acts"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></span></span></div>
                  <div class="gv-row"><span class="grip">⠿</span><span class="nm">Earthworks</span><span class="right"><span class="gv-pill-s"><span class="gv-spark">✦</span>suggested</span><span class="ix">2</span><span class="acts"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></span></span></div>
                  <div class="gv-row"><span class="grip">⠿</span><span class="nm">Concrete works</span><span class="right"><span class="gv-pill-s"><span class="gv-spark">✦</span>suggested</span><span class="ix">3</span><span class="acts"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></span></span></div>
                  <div class="gv-row"><span class="grip">⠿</span><span class="nm">Masonry works</span><span class="right"><span class="gv-pill-s"><span class="gv-spark">✦</span>suggested</span><span class="ix">4</span><span class="acts"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></span></span></div>
                  <div class="gv-add"><div class="gv-input">New section name…</div><span class="gv-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>{t('mock.addSection')}</span></div>
                </div>
              </div>
            </div>
            </div>
          </div>
        </div>
        <div class="cap1-bridge" aria-hidden="true">
          <span class="cap1-bridge-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.6 6.4L20 10l-6.4 1.6L12 18l-1.6-6.4L4 10l6.4-1.6z"/></svg></span>
          <span class="cap1-bridge-t">Gradvera analyzes similar completed projects</span>
          <span class="cap1-bridge-ln"></span>
        </div>
        <div class="cap1-step rev" role="listitem">
          <div class="cap1-text">
            <span class="cap1-badge" aria-hidden="true">2</span>
            <div class="cap1-stepk">Step 2</div>
            <h3 class="cap1-steph">{t('cap1.step2h')}</h3>
            <p class="cap1-stepd">{t('cap1.step2d')}</p>
          </div>
          <div class="gv-panelwrap" aria-hidden="true">
            <div class="winbar app"><span class="dots"><i></i><i></i><i></i></span><span class="wtitle"><img src="/assets/monogram-plain.svg" alt="">Gradvera · Adding items</span></div>
            <div class="gv-holder">
            <div class="gv-screen solo gv-screen-2" style="--gw:800px">
              <div class="gv-main">
                <div class="gv-top2">
                  <div>
                    <div class="ttl">Sidewalk project</div>
                    <div class="st">New estimate · Step 3 of 5 · Adding items</div>
                  </div>
                  <div class="r">
                    <span class="gv-ghostlink"><span class="gv-spark">✦</span> Auto-suggest items</span>
                    <span class="gv-btn">Next: Risk review <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
                  </div>
                </div>
                <div class="gv-stepper">
                  <span class="gv-step done"><span class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></span>Basic data</span>
                  <span class="sep done"></span>
                  <span class="gv-step done"><span class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></span>Estimate structure</span>
                  <span class="sep done"></span>
                  <span class="gv-step act"><span class="dot">3</span>Adding items</span>
                  <span class="sep"></span>
                  <span class="gv-step"><span class="dot">4</span>Risk review</span>
                  <span class="sep"></span>
                  <span class="gv-step"><span class="dot">5</span>Finalise</span>
                </div>
                <div class="gv-banner">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  <div><div class="bt">20 items added with awaiting confirmation status</div><div class="bd">They will sit at the bottom of the table until reviewed. Prices are suggested, not final.</div></div>
                </div>
                <div class="gv-panel">
                  <div class="ph"><span class="pt"><span class="gv-spark">✦</span> Auto-suggest items</span><span class="close">{t('mock.close')} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span></div>
                  <div class="pmeta">
                    <span class="sel"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>18 selected</span>
                    <span class="pstat">{t('mock.confidence')}<b class="cf m">{t('mock.medium')}</b></span>
                    <span class="pdiv"></span>
                    <span class="pstat">{t('mock.sources')}<b>5 projects</b></span>
                    <span class="pdiv"></span>
                    <span class="pstat">{t('mock.lineItems')}<b>402</b></span>
                    <span class="adj"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>Adjust matching</span>
                  </div>
                  <div class="gv-irow"><div><div class="inm">Site setup and fencing</div><div class="isub">Preparatory · Project 2024 #013 · <span class="ai"><span class="gv-spark">✦</span>AI suggestion</span></div></div><div class="ir"><div class="iq">1.00 kpl</div><div class="ip">€11,014.11<span style="font-weight:400;color:var(--fg3)">/kpl</span></div></div><span class="gv-conf h">{t('mock.high')}</span></div>
                  <div class="gv-irow"><div><div class="inm">Relocation of utility lines</div><div class="isub">Preparatory · Project 2024 #013 · <span class="ai"><span class="gv-spark">✦</span>AI suggestion</span></div></div><div class="ir"><div class="iq">1.00 kpl</div><div class="ip">€5,410.35<span style="font-weight:400;color:var(--fg3)">/kpl</span></div></div><span class="gv-conf h">{t('mock.high')}</span></div>
                  <div class="gv-irow"><div><div class="inm">Wide machine excavation, category III</div><div class="isub">Earthworks · Standard item · A12 · <span class="ai"><span class="gv-spark">✦</span>AI suggestion</span></div></div><div class="ir"><div class="iq">427.66 m³</div><div class="ip">€10.44<span style="font-weight:400;color:var(--fg3)">/m³</span></div></div><span class="gv-conf m">{t('mock.medium')}</span></div>
                  <div class="gv-irow"><div><div class="inm">Protective layer of crushed stone</div><div class="isub">Earthworks · Project 2024 #013 · <span class="ai"><span class="gv-spark">✦</span>AI suggestion</span></div></div><div class="ir"><div class="iq">615.33 m³</div><div class="ip">€28.22<span style="font-weight:400;color:var(--fg3)">/m³</span></div></div><span class="gv-conf l">{t('mock.low')}</span></div>
                </div>
                <div class="gv-foot"><span class="ft">Suggested items will be added with <b style="color:var(--fg2)">awaiting confirmation</b> status. Prices are suggested, not final.</span><span class="r"><span class="gv-btn ghost">{t('mock.cancel')}</span><span class="gv-btn">Add 18 items</span></span></div>
              </div>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
