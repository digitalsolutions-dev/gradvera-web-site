---
import { useTranslations, type Locale } from '../../i18n/utils';
interface Props { lang: Locale }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<style is:global>
  .legal-page { background: var(--bg2); padding-top: 120px; }
  .legal-hero { background: var(--ink); color: var(--on-ink); padding: clamp(96px,14vh,176px) 0 clamp(40px,6vh,72px); }
  .legal-hero h1 { font-weight: 600; font-size: clamp(34px,5vw,60px); line-height: 1.04; letter-spacing: -0.025em; color: var(--on-ink); margin: 0; }
  .legal-hero p.sub { color: var(--on-ink-2); font-size: 16px; line-height: 1.6; margin: 20px 0 0; max-width: 640px; }
  .legal-body { max-width: var(--maxw); margin: 0 auto; padding: clamp(24px,3.5vh,44px) var(--pad) clamp(64px,9vh,120px); }
  .legal-body h2 { font-weight: 600; font-size: clamp(24px,2.8vw,34px); line-height: 1.12; letter-spacing: -0.02em;
    color: var(--fg1); margin: clamp(40px,5vh,64px) 0 18px; padding-top: clamp(24px,3vh,40px); border-top: 1px solid var(--border2); }
  .legal-body h2:first-of-type { border-top: 0; padding-top: 0; margin-top: 0; }
  .legal-body h3 { font-weight: 600; font-size: clamp(17px,1.6vw,21px); line-height: 1.2; letter-spacing: -0.012em;
    color: var(--fg1); margin: 30px 0 12px; }
  .legal-body p { font-size: 15.5px; line-height: 1.68; color: var(--fg2); margin: 0 0 16px; max-width: 70ch; text-wrap: pretty; }
  .legal-body a { color: var(--brand-blue); }
  .legal-body a:hover { color: var(--brand-primary-soft-text); text-decoration: underline; }
  .legal-body ul { margin: 0 0 18px; padding-left: 22px; display: flex; flex-direction: column; gap: 9px; }
  .legal-body li { font-size: 15.5px; line-height: 1.55; color: var(--fg2); }
  .legal-body li::marker { color: var(--amber); }
  /* "Details" call-out block */
  .legal-details { background: var(--bg1); border: 1px solid var(--border2); border-left: 3px solid var(--amber);
    border-radius: 10px; padding: 20px 22px; margin: 4px 0 28px; }
  .legal-details .dh { display: inline-flex; align-items: center; gap: 8px; font: 600 11px/1 var(--font-mono);
    text-transform: uppercase; letter-spacing: 0.12em; color: var(--brand-primary-pressed); margin-bottom: 14px; }
  .legal-details .dh .gv-spark { color: var(--amber); }
  .legal-details dl { margin: 0; display: grid; grid-template-columns: auto 1fr; gap: 10px 18px; }
  .legal-details dt { font: 500 11px/1.5 var(--font-mono); text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg-label); white-space: nowrap; }
  .legal-details dd { margin: 0; font-size: 14px; line-height: 1.55; color: var(--fg2); }
  @media (max-width: 600px){ .legal-details dl { grid-template-columns: 1fr; gap: 3px 0; } .legal-details dd { margin-bottom: 12px; } }
  .legal-updated { font: 500 13px/1.5 var(--font-mono); color: var(--fg2); margin: 0 0 clamp(28px,4vh,44px); }
</style>

<!-- ============ HERO ============ -->
<section class="legal-hero">
  <div class="wrap">
    <h1>{t('privacy.hero.title')}</h1>
    <p class="sub">{t('privacy.hero.sub')}</p>
  </div>
</section>

<div class="legal-page">
  <div class="legal-body">

    <p class="legal-updated">{t('privacy.updated')}</p>
    <h2>{t('privacy.basic.title')}</h2>
    <p>{t('privacy.basic.controller')}</p>
    <p><strong>{t('privacy.basic.gdprLabel')}</strong> {t('privacy.basic.gdpr')}</p>

    <h2>{t('privacy.rights.title')}</h2>
    <p>{t('privacy.rights.intro')}</p>
    <ul>
      {t('privacy.rights.items').map((s: string) => (<li>{s}</li>))}
    </ul>
    <p>{t('privacy.rights.exercise.pre')}<a href="mailto:info@gradvera.com">info@gradvera.com</a>{t('privacy.rights.exercise.post')}</p>
    <p><strong>{t('privacy.rights.complaintLabel')}</strong> {t('privacy.rights.complaint')}</p>

    <h2>{t('privacy.purposes.title')}</h2>

    <h3>{t('privacy.visit.title')}</h3>
    <p>{t('privacy.visit.p1')}</p>
    <p>{t('privacy.visit.p2')}</p>
    <div class="legal-details">
      <span class="dh"><span class="gv-spark" aria-hidden="true">✦</span>{t('privacy.detailsLabel')}</span>
      <dl>
        <dt>{t('privacy.term.legalBasis')}</dt><dd>{t('privacy.visit.detail.legalBasis')}</dd>
        <dt>{t('privacy.term.userCategories')}</dt><dd>{t('privacy.visit.detail.userCategories')}</dd>
        <dt>{t('privacy.term.transfers')}</dt><dd>{t('privacy.visit.detail.transfers')}</dd>
        <dt>{t('privacy.term.storagePeriod')}</dt><dd>{t('privacy.visit.detail.storagePeriod')}</dd>
      </dl>
    </div>

    <h3>{t('privacy.contact.title')}</h3>
    <p>{t('privacy.contact.p1')}</p>
    <div class="legal-details">
      <span class="dh"><span class="gv-spark" aria-hidden="true">✦</span>{t('privacy.detailsLabel')}</span>
      <dl>
        <dt>{t('privacy.term.legalBasis')}</dt><dd>{t('privacy.contact.detail.legalBasis')}</dd>
        <dt>{t('privacy.term.userCategories')}</dt><dd>{t('privacy.contact.detail.userCategories')}</dd>
        <dt>{t('privacy.term.storagePeriod')}</dt><dd>{t('privacy.contact.detail.storagePeriod')}</dd>
      </dl>
    </div>

    <h3>{t('privacy.inquiry.title')}</h3>
    <p>{t('privacy.inquiry.p1')}</p>
    <p>{t('privacy.inquiry.p2')}</p>
    <div class="legal-details">
      <span class="dh"><span class="gv-spark" aria-hidden="true">✦</span>{t('privacy.detailsLabel')}</span>
      <dl>
        <dt>{t('privacy.term.legalBasis')}</dt><dd>{t('privacy.inquiry.detail.legalBasis')}</dd>
        <dt>{t('privacy.term.userCategories')}</dt><dd>{t('privacy.inquiry.detail.userCategories')}</dd>
        <dt>{t('privacy.term.storagePeriod')}</dt><dd>{t('privacy.inquiry.detail.storagePeriod')}</dd>
      </dl>
    </div>

    <h3>{t('privacy.newsletter.title')}</h3>
    <p>{t('privacy.newsletter.p1')}</p>
    <p>{t('privacy.newsletter.p2')}</p>
    <div class="legal-details">
      <span class="dh"><span class="gv-spark" aria-hidden="true">✦</span>{t('privacy.detailsLabel')}</span>
      <dl>
        <dt>{t('privacy.term.legalBasis')}</dt><dd>{t('privacy.newsletter.detail.legalBasis')}</dd>
        <dt>{t('privacy.term.userCategories')}</dt><dd>{t('privacy.newsletter.detail.userCategories')}</dd>
        <dt>{t('privacy.term.storagePeriod')}</dt><dd>{t('privacy.newsletter.detail.storagePeriod')}</dd>
        <dt>{t('privacy.term.unsubscribe')}</dt><dd>{t('privacy.newsletter.detail.unsubscribe')}</dd>
        <dt>{t('privacy.term.complaint')}</dt><dd>{t('privacy.newsletter.detail.complaint')}</dd>
      </dl>
    </div>

    <h3>{t('privacy.job.title')}</h3>
    <p>{t('privacy.job.p1')}</p>
    <p>{t('privacy.job.p2')}</p>
    <p>{t('privacy.job.p3')}</p>
    <div class="legal-details">
      <span class="dh"><span class="gv-spark" aria-hidden="true">✦</span>{t('privacy.detailsLabel')}</span>
      <dl>
        <dt>{t('privacy.term.legalBasis')}</dt><dd>{t('privacy.job.detail.legalBasis')}</dd>
        <dt>{t('privacy.term.userCategories')}</dt><dd>{t('privacy.job.detail.userCategories')}</dd>
        <dt>{t('privacy.term.storagePeriod')}</dt><dd>{t('privacy.job.detail.storagePeriod')}</dd>
      </dl>
    </div>

    <h2>{t('privacy.analytics.title')}</h2>
    <p>{t('privacy.analytics.p1')}</p>
    <div class="legal-details">
      <span class="dh"><span class="gv-spark" aria-hidden="true">✦</span>{t('privacy.detailsLabel')}</span>
      <dl>
        <dt>{t('privacy.term.legalBasis')}</dt><dd>{t('privacy.analytics.detail.legalBasis')}</dd>
        <dt>{t('privacy.term.userCategories')}</dt><dd>{t('privacy.analytics.detail.userCategories')}</dd>
        <dt>{t('privacy.term.storagePeriod')}</dt><dd>{t('privacy.analytics.detail.storagePeriod')}</dd>
      </dl>
    </div>

  </div>
</div>
