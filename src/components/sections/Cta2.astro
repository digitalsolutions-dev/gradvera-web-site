---
import { useTranslations, localizePath, type Locale } from '../../i18n/utils';
interface Props { lang: Locale; path?: string }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="cta2">
  <div class="wrap reveal">
    <h2>{t('cta2.h2')}</h2>
    <a class="btn btn-primary btn-lg" href={localizePath('/book-a-demo/', lang)}>{t('cta2.cta')}</a>
  </div>
</section>
