---
import { useTranslations, type Locale } from '../../i18n/utils';
interface Props { lang: Locale; path?: string }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="results">
  <div class="wrap">
    <div class="reveal">
      <p class="eyebrow">{t('results.eyebrow')}</p>
      <h2>{t('results.h2')}</h2>
      <p class="lede">{t('results.lede')}</p>
    </div>
    <div class="metrics reveal">
      <div class="metric">
        <div class="mv">82%</div>
        <div class="ml">{t('results.m1l')}</div>
        <div class="ms">{t('results.m1s')}</div>
      </div>
      <div class="metric">
        <div class="mv">5×</div>
        <div class="ml">{t('results.m2l')}</div>
      </div>
      <div class="metric">
        <div class="mv">95%</div>
        <div class="ml">{t('results.m3l')}</div>
      </div>
    </div>
  </div>
</section>
