# ---------------------------------------------------------------------------
# Gradvera website — environment configuration. Copy to `.env` and fill in.
# Vars prefixed PUBLIC_ are exposed to client JS (Astro convention). Everything
# else is server-only (read inside the /api/lead serverless function).
# ---------------------------------------------------------------------------

# Canonical production origin (no trailing slash). Used for canonical URLs,
# hreflang, OG tags, sitemap and robots. CONFIRM THE REAL DOMAIN before launch.
PUBLIC_SITE_URL=https://www.gradvera.com

# Google Tag Manager container id (GA4 is configured inside GTM). Leave blank
# to disable analytics entirely. Loaded via Partytown, gated behind consent.
PUBLIC_GTM_ID=

# Optional: direct GA4 Measurement id, only if you load GA4 outside GTM.
PUBLIC_GA4_ID=

# ---- Lead capture (server-side, used by src/pages/api/lead.ts) ----
# Public endpoint of the gtm-toolkit inbound-lead service. When set, the
# website forwards demo/contact submissions here (HMAC-signed). When blank,
# /api/lead validates + logs the lead and returns 200 (no-op forward) so the
# site works before the toolkit endpoint exists.
GTM_LEAD_ENDPOINT=
# Shared secret for HMAC-SHA256 request signing (X-Gradvera-Signature header).
GTM_LEAD_SECRET=
# Where to email a fallback copy of each lead (optional).
LEAD_NOTIFY_EMAIL=info@digitalsolutions.si
